[{"state":"greeting","description":"Initial interaction — welcome and present main options","allowed_actions":["show_menu","ask_market","handoff"],"entry_trigger":"new_session","exit_conditions":["view_products","shipping_info","human_help"],"fallback":"re_show_menu"},{"state":"market_selection","description":"Route the user to the correct catalog and pricing by country","allowed_actions":["select_catalog","ask_again","handoff"],"entry_trigger":"view_products or shipping_info","exit_conditions":["country_mx","country_us"],"fallback":"ask_again"},{"state":"product_interest","description":"Show available products for the selected market","allowed_actions":["show_product_list","offer_support","handoff"],"entry_trigger":"market confirmed with product intent","exit_conditions":["product_[key] selected"],"fallback":"offer_handoff"},{"state":"product_education","description":"Provide product information, benefits, and FAQ","allowed_actions":["send_content","ask_readiness","handoff"],"entry_trigger":"product_information intent detected","exit_conditions":["checkout_ready","human_help"],"fallback":"offer_handoff"},{"state":"checkout_intent","description":"Confirm purchase intent and collect quantity","allowed_actions":["show_quantity_options","offer_handoff"],"entry_trigger":"checkout intent confirmed","exit_conditions":["qty_1","qty_2","qty_other"],"fallback":"re_show_options"},{"state":"checkout_confirm","description":"Show order summary and generate payment link","allowed_actions":["generate_checkout_path","change_selection","handoff"],"entry_trigger":"quantity confirmed","exit_conditions":["generate_checkout","change_selection"],"fallback":"re_show_summary"},{"state":"follow_up","description":"Post-contact nurturing for non-converted leads","allowed_actions":["send_template","offer_return","close"],"entry_trigger":"time_elapsed or re_engagement_trigger","exit_conditions":["checkout_ready","unsubscribe"],"fallback":"close_sequence"},{"state":"handoff","description":"Human operator takes over — bot is silent","allowed_actions":["notify_team","preserve_context"],"entry_trigger":"explicit_request or guardrail_failure or fallback_limit","exit_conditions":["human_resets_session"],"fallback":"remain_silent"},{"state":"closed","description":"Purchase completed or conversation ended","allowed_actions":["send_confirmation","trigger_post_sale"],"entry_trigger":"payment_confirmed","exit_conditions":[],"fallback":"none"}]
